<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stockaholic - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;700&display=swap"
        rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Syne', 'sans-serif'], mono: ['DM Mono', 'monospace'] },
                    colors: {
                        bg: '#0f1117',
                        sidebar: '#13161f',
                        surface: '#181c27',
                        surface2: '#1e2334',
                        accent: '#4ade80',
                        accent2: '#38bdf8',
                        accent3: '#f59e0b',
                        danger: '#f87171',
                        border: 'rgba(255,255,255,0.07)',
                        muted: '#6b7280',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #0f1117;
            color: #e8eaf0;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-thumb {
            background: #1e2334;
            border-radius: 2px;
        }

        .nav-active {
            background: rgba(74, 222, 128, 0.08);
            color: #4ade80;
            border: 1px solid rgba(74, 222, 128, 0.15);
        }

        .bar-fill {
            transition: width 1s ease;
        }

        input,
        select,
        textarea {
        background: #1e2334 !important;
        color: #e8eaf0 !important;
        border: 1px solid rgba(255, 255, 255, 0.07) !important;
        outline: none;
        }

        input:focus,
        select:focus,
        textarea:focus {
        border-color: rgba(74, 222, 128, 0.35) !important;
        }

        input::placeholder,
        textarea::placeholder {
        color: #6b7280;
        }
    </style>
</head>

<body class="flex h-screen overflow-hidden font-sans">

    <!-- Sidebar -->
    <aside class="w-56 min-w-56 flex flex-col"
        style="background:#13161f; border-right:1px solid rgba(255,255,255,0.07)">
        <div class="px-5 py-6" style="border-bottom:1px solid rgba(255,255,255,0.07)">
            <p class="text-lg font-bold tracking-tight">Stock<span class="text-accent">aholic</span></p>
            <p class="font-mono text-muted mt-1" style="font-size:10px; letter-spacing:1px; text-transform:uppercase">
                v0.1.0 — warehouse</p>
        </div>

        <nav class="flex-1 p-3 flex flex-col gap-0.5">
            <p class="font-mono text-muted px-2 pt-3 pb-1.5"
                style="font-size:10px; letter-spacing:1.5px; text-transform:uppercase">Main</p>
            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" &&
                ViewContext.RouteData.Values["action"]?.ToString() == "Index")
            {
                <a asp-controller="Dashboard" asp-action="Index"
                    class="nav-active flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm cursor-pointer">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <rect x="3" y="3" width="7" height="7" rx="1" />
                        <rect x="14" y="3" width="7" height="7" rx="1" />
                        <rect x="3" y="14" width="7" height="7" rx="1" />
                        <rect x="14" y="14" width="7" height="7" rx="1" />
                    </svg>
                    Dashboard
                </a>
            } else {
                <a asp-controller="Dashboard" asp-action="Index"
                class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm text-muted hover:bg-surface2 hover:text-white transition-all cursor-pointer"
                style="border:1px solid transparent">
                <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
                Dashboard
            </a>
            }
            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Produtos" &&
                ViewContext.RouteData.Values["action"]?.ToString() == "Index")
            {
                <a asp-controller="Produtos" asp-action="Index"
                    class="nav-active flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm cursor-pointer">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path
                            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                    Produtos
                </a>
            } else {
                <a asp-controller="Produtos" asp-action="Index"
                    class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm text-muted hover:bg-surface2 hover:text-white transition-all cursor-pointer"
                    style="border:1px solid transparent">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path
                            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                    Produtos
                </a>
            }
            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Movimentos" &&
                ViewContext.RouteData.Values["action"]?.ToString() == "Index")
            {
                <a asp-controller="Movimentos" asp-action="Index"
                    class="nav-active flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm cursor-pointer">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2">
                        <path d="M17 3l4 4-4 4" />
                        <path d="M3 11V9a4 4 0 0 1 4-4h14" />
                        <path d="M7 21l-4-4 4-4" />
                        <path d="M21 13v2a4 4 0 0 1-4 4H3" />
                    </svg>
                    Movimentos
                </a>
            } else {
                <a asp-controller="Movimentos" asp-action="Index"
                    class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm text-muted hover:bg-surface2 hover:text-white transition-all cursor-pointer"
                    style="border:1px solid transparent">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M17 3l4 4-4 4" />
                        <path d="M3 11V9a4 4 0 0 1 4-4h14" />
                        <path d="M7 21l-4-4 4-4" />
                        <path d="M21 13v2a4 4 0 0 1-4 4H3" />
                    </svg>
                    Movimentos
                </a>
            }
            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Categorias" &&
                ViewContext.RouteData.Values["action"]?.ToString() == "Index")
            {
                <a asp-controller="Categorias" asp-action="Index"
                    class="nav-active flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm cursor-pointer">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2">
                        <path d="M4 6h16M4 12h10M4 18h6" />
                    </svg>
                    Categorias
                </a>
            } else {
                <a asp-controller="Categorias" asp-action="Index"
                    class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm text-muted hover:bg-surface2 hover:text-white transition-all cursor-pointer"
                    style="border:1px solid transparent">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2">
                        <path d="M4 6h16M4 12h10M4 18h6" />
                    </svg>
                    Categorias
                </a>
            }
            <p class="font-mono text-muted px-2 pt-3 pb-1.5"
                style="font-size:10px; letter-spacing:1.5px; text-transform:uppercase">Admin</p>
            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Utilizadores" &&
                ViewContext.RouteData.Values["action"]?.ToString() == "Index")
            {
                <a asp-controller="Utilizadores" asp-action="Index"
                    class="nav-active flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm cursor-pointer">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    Utilizadores
                </a>
            } else {
                <a asp-controller="Utilizadores" asp-action="Index"
                    class="flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-sm text-muted hover:bg-surface2 hover:text-white transition-all cursor-pointer"
                    style="border:1px solid transparent">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    Utilizadores
                </a>
            }
        </nav>

        <div class="p-3" style="border-top:1px solid rgba(255,255,255,0.07)">
            <div class="flex items-center gap-2.5 p-2 rounded-lg bg-surface2">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-medium text-accent flex-shrink-0"
                    style="background:rgba(74,222,128,0.15)">AD</div>
                <div>
                    <p class="text-xs font-medium">Admin</p>
                    <p class="font-mono text-muted" style="font-size:10px">admin@stock.io</p>
                </div>
            </div>
        </div>
    </aside>

    @RenderBody()
</body>

</html>