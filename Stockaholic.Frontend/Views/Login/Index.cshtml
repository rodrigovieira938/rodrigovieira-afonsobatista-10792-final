@{
    ViewData["Title"] = "Login";
    Layout = "";
}

<!DOCTYPE html>
<html lang="pt">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stockaholic — Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;700&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Syne', 'sans-serif'], mono: ['DM Mono', 'monospace'] },
          colors: {
            bg: '#0f1117', surface: '#181c27', surface2: '#1e2334',
            accent: '#4ade80', muted: '#6b7280', danger: '#f87171',
          },
          keyframes: {
            fadein: { from: { opacity: '0', transform: 'translateY(16px)' }, to: { opacity: '1', transform: 'translateY(0)' } }
          },
          animation: { fadein: 'fadein 0.5s ease forwards' }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: #0f1117;
      color: #e8eaf0;
    }

    input {
      background: #1e2334 !important;
      color: #e8eaf0 !important;
      border: 1px solid rgba(255, 255, 255, 0.07) !important;
      outline: none;
      transition: border 0.15s;
    }

    input:focus {
      border-color: rgba(74, 222, 128, 0.4) !important;
      box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.08);
    }

    input::placeholder {
      color: #6b7280;
    }

    .grid-bg {
      background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .glow {
      box-shadow: 0 0 60px rgba(74, 222, 128, 0.08), 0 0 120px rgba(74, 222, 128, 0.04);
    }

    @@keyframes fadein {
      from {
        opacity: 0;
        transform: translateY(16px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fadein {
      animation: fadein 0.5s ease forwards;
    }

    .animate-fadein-d1 {
      animation: fadein 0.5s ease 0.1s both;
    }

    .animate-fadein-d2 {
      animation: fadein 0.5s ease 0.2s both;
    }

    .animate-fadein-d3 {
      animation: fadein 0.5s ease 0.3s both;
    }

    .animate-fadein-d4 {
      animation: fadein 0.5s ease 0.4s both;
    }
  </style>
</head>

<body class="min-h-screen grid-bg flex items-center justify-center p-4">

  <!-- Subtle radial glow -->
  <div class="fixed inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(74,222,128,0.04) 0%, transparent 70%)"></div>

  <div class="w-full max-w-sm relative">

    <!-- Logo -->
    <div class="text-center mb-10 animate-fadein">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-4 glow"
        style="background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.2)">
        <svg class="w-6 h-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path
            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold tracking-tight">Stock<span class="text-accent">aholic</span></h1>
      <p class="text-muted text-xs font-mono mt-1 tracking-widest uppercase">warehouse management</p>
    </div>

    <!-- Card -->
    <div class="rounded-2xl p-8 glow" style="background:#13161f; border:1px solid rgba(255,255,255,0.08)">

      <div class="animate-fadein-d1">
        <h2 class="text-base font-medium mb-1">Bem-vindo de volta</h2>
        <p class="text-xs text-muted mb-6">Inicie sessão para continuar</p>
      </div>

      <div id="error-msg" class="hidden mb-4 px-3 py-2.5 rounded-lg text-xs text-danger font-mono"
        style="background:rgba(248,113,113,0.08); border:1px solid rgba(248,113,113,0.15)">
        Email ou password incorretos.
      </div>

      <form onsubmit="handleLogin(event)" class="flex flex-col gap-4">

        <div class="flex flex-col gap-1.5 animate-fadein-d2">
          <label class="font-mono text-muted uppercase tracking-wider" style="font-size:10px">Email</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted pointer-events-none"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            <input id="email" type="email" placeholder="admin@stock.io"
              class="w-full pl-9 pr-3 py-2.5 rounded-lg text-sm" autocomplete="email" />
          </div>
        </div>

        <div class="flex flex-col gap-1.5 animate-fadein-d3">
          <label class="font-mono text-muted uppercase tracking-wider" style="font-size:10px">Password</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted pointer-events-none"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <input id="password" type="password" placeholder="••••••••"
              class="w-full pl-9 pr-10 py-2.5 rounded-lg text-sm" autocomplete="current-password" />
            <button type="button" onclick="togglePwd()"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-muted hover:text-white transition-colors">
              <svg id="eye-icon" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
        </div>

        <div class="animate-fadein-d4 mt-2 flex flex-col gap-3">
          <button id="login-btn" type="submit"
            class="w-full py-2.5 rounded-lg text-sm font-medium text-bg bg-accent hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2">
            <span id="btn-text">Entrar</span>
            <svg id="btn-arrow" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
            <svg id="btn-spinner" class="w-4 h-4 hidden animate-spin" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path
                d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
          </button>
          <button type="button" onclick="openForgot()"
            class="text-xs text-muted hover:text-white transition-colors font-mono text-center">
            Esqueceu-se da password?
          </button>
        </div>

      </form>
    </div>

    <p class="text-center text-muted font-mono mt-6" style="font-size:10px; letter-spacing:0.5px">
      STOCKAHOLIC © 2025 — TODOS OS DIREITOS RESERVADOS
    </p>
  </div>

  <!-- Forgot Password Modal -->
  <div id="forgot-modal" class="fixed inset-0 flex items-center justify-center z-50 hidden"
    style="background:rgba(0,0,0,0.7)">
    <div class="w-96 rounded-2xl overflow-hidden glow"
      style="background:#13161f; border:1px solid rgba(255,255,255,0.1)">

      <!-- Step 1: Enter email -->
      <div id="step-email">
        <div class="px-6 py-5 flex items-center justify-between" style="border-bottom:1px solid rgba(255,255,255,0.07)">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(74,222,128,0.1)">
              <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </div>
            <h2 class="text-sm font-medium">Recuperar password</h2>
          </div>
          <button onclick="closeForgot()" class="text-muted hover:text-white text-xl leading-none px-1">×</button>
        </div>
        <div class="p-6 flex flex-col gap-4">
          <p class="text-xs text-muted leading-relaxed">Introduza o seu email e enviaremos um link para redefinir a sua
            password.</p>
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-muted uppercase tracking-wider" style="font-size:10px">Email</label>
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted pointer-events-none"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <input id="forgot-email" type="email" placeholder="o-seu@email.com"
                class="w-full pl-9 pr-3 py-2.5 rounded-lg text-sm" />
            </div>
          </div>
          <div id="forgot-error" class="hidden px-3 py-2 rounded-lg text-xs text-danger font-mono"
            style="background:rgba(248,113,113,0.08); border:1px solid rgba(248,113,113,0.15)">
            Introduza um email válido.
          </div>
        </div>
        <div class="px-6 pb-6 flex gap-2 justify-end">
          <button onclick="closeForgot()" class="px-4 py-2 rounded-lg text-xs font-medium text-muted"
            style="background:#1e2334; border:1px solid rgba(255,255,255,0.07)">Cancelar</button>
          <button onclick="sendReset()" id="send-btn"
            class="px-4 py-2 rounded-lg text-xs font-medium text-bg bg-accent hover:opacity-90 flex items-center gap-2">
            <span id="send-text">Enviar link</span>
            <svg id="send-spinner" class="w-3.5 h-3.5 hidden animate-spin" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2">
              <path
                d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Step 2: Success screen -->
      <div id="step-success" class="hidden p-8 flex flex-col items-center text-center gap-4">
        <div class="w-14 h-14 rounded-full flex items-center justify-center"
          style="background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.2)">
          <svg class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium mb-1">Email enviado!</p>
          <p class="text-xs text-muted leading-relaxed">Enviámos um link de recuperação para <span id="sent-to"
              class="text-accent font-mono"></span>. Verifique a sua caixa de entrada.</p>
        </div>
        <p class="text-accent font-mono">O seu email deve aparacer assim:</p>
        <!-- Fake email preview -->
        <div class="w-full rounded-xl p-4 text-left mt-2"
          style="background:#0f1117; border:1px solid rgba(255,255,255,0.07)">
          <div class="flex items-center gap-2 mb-3"
            style="border-bottom:1px solid rgba(255,255,255,0.07); padding-bottom:10px">
            <div class="w-6 h-6 rounded flex items-center justify-center flex-shrink-0"
              style="background:rgba(74,222,128,0.15)">
              <svg class="w-3.5 h-3.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <path
                  d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-medium">Stockaholic</p>
              <p class="font-mono text-muted" style="font-size:10px">noreply@stockaholic.io</p>
            </div>
            <span class="ml-auto font-mono text-muted" style="font-size:10px">agora</span>
          </div>
          <p class="text-xs font-medium mb-2">Recuperação de password</p>
          <p class="text-xs text-muted leading-relaxed mb-3">Recebemos um pedido para redefinir a password da sua conta.
            Clique no botão abaixo para continuar.</p>
          <div class="flex justify-center">
            <span class="px-4 py-1.5 rounded-lg text-xs font-medium text-bg bg-accent">Redefinir password</span>
          </div>
          <p class="text-muted mt-3 leading-relaxed" style="font-size:10px; font-family:'DM Mono',monospace">Este link
            expira em 30 minutos. Se não pediu esta recuperação, ignore este email.</p>
        </div>

        <button onclick="closeForgot()"
          class="px-6 py-2 rounded-lg text-xs font-medium text-muted hover:text-white transition-colors"
          style="background:#1e2334; border:1px solid rgba(255,255,255,0.07)">
          Fechar
        </button>
      </div>

    </div>
  </div>

  <script>
    function togglePwd() {
      const inp = document.getElementById('password');
      const icon = document.getElementById('eye-icon');
      if (inp.type === 'password') {
        inp.type = 'text';
        icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
      } else {
        inp.type = 'password';
        icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
      }
    }

    // ── Fake Email API ──────────────────────────────────────
    // Simulates POST /api/email/send to a mock email service.
    // In production, replace this with a real call to your
    // email provider (SendGrid, Mailgun, etc.)
    async function fakeEmailApi(to, template) {
      const latency = Math.floor(Math.random() * 400) + 300; // 300–700ms
      await new Promise(r => setTimeout(r, latency));
      // Simulate occasional failure (10% chance) — remove in prod
      if (Math.random() < 0.1) throw new Error('Email service unavailable');
      return { status: 200, latency, to, template, provider: 'MockMail v1.0' };
    }

    function openForgot() {
      document.getElementById('forgot-modal').classList.remove('hidden');
      document.getElementById('step-email').classList.remove('hidden');
      document.getElementById('step-success').classList.add('hidden');
      document.getElementById('forgot-email').value = '';
      document.getElementById('forgot-error').classList.add('hidden');
    }

    function closeForgot() {
      document.getElementById('forgot-modal').classList.add('hidden');
    }

    async function sendReset() {
      const email = document.getElementById('forgot-email').value.trim();
      const errEl = document.getElementById('forgot-error');
      errEl.classList.add('hidden');

      if (!email || !email.includes('@@')) {
        errEl.classList.remove('hidden');
        return;
      }

      // Loading state
      document.getElementById('send-text').textContent = 'A enviar...';
      document.getElementById('send-spinner').classList.remove('hidden');
      document.getElementById('send-btn').disabled = true;

      try {
        const result = await fakeEmailApi(email, 'password_reset');

        // Show success step
        document.getElementById('step-email').classList.add('hidden');
        document.getElementById('step-success').classList.remove('hidden');
        document.getElementById('sent-to').textContent = email;
        document.getElementById('log-email').textContent = email;
        document.getElementById('fake-latency').textContent = result.latency;
      } catch (err) {
        errEl.textContent = 'Serviço de email indisponível. Tente novamente.';
        errEl.classList.remove('hidden');
      } finally {
        document.getElementById('send-text').textContent = 'Enviar link';
        document.getElementById('send-spinner').classList.add('hidden');
        document.getElementById('send-btn').disabled = false;
      }
    }
    // ────────────────────────────────────────────────────────

    async function handleLogin(e) {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        document.getElementById('btn-text').textContent = 'A entrar...';
        document.getElementById('btn-arrow').classList.add('hidden');
        document.getElementById('btn-spinner').classList.remove('hidden');
        document.getElementById('error-msg').classList.add('hidden');
        setTimeout(async () => {
            try {
                const response = await fetch('login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                if(response.status == 200) {
                    window.location.href = 'dashboard';
                } else {
                    document.getElementById('btn-text').textContent = 'Entrar';
                    document.getElementById('btn-arrow').classList.remove('hidden');
                    document.getElementById('btn-spinner').classList.add('hidden');
                    document.getElementById('error-msg').classList.remove('hidden');
                }
                console.log(response.status)
            } catch (error) {
                const error_msg = document.getElementById('error-msg');
                const backup = error_msg.innerHTML;
                error_msg.classList.remove('hidden');
                error_msg.innerHTML = "Erro: \"" + error.message + "\". Tente novamente.";

                setTimeout(() => {
                    second();
                    error_msg.classList.add('hidden');
                    error_msg.innerHTML = backup;
                }, 1000);
                console.error(error.message);
            }
        }, 900);
        


        // Simulate API call
        /*setTimeout(() => {
            document.getElementById('btn-text').textContent = 'Entrar';
            document.getElementById('btn-arrow').classList.remove('hidden');
            document.getElementById('btn-spinner').classList.add('hidden');

            if (email === 'admin@stock.io' && password === 'admin') {
            window.location.href = 'dashboard.html';
            } else {
            document.getElementById('error-msg').classList.remove('hidden');
            document.getElementById('password').value = '';
            }
        }, 900);*/
        }
  </script>
</body>

</html>